# ============================================================
# App BiT Backend — Production Environment Variables
# ============================================================
# Copy this file to .env.prod, fill in real values, and
# load it via Docker, Render dashboard, or docker-compose.
#
# DO NOT commit .env.prod or any file with real credentials.
# ============================================================

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
NODE_ENV=production
PORT=3000
API_URL=https://app-bit-backend.onrender.com
CORS_ORIGIN=https://app-bit.vercel.app

# ------------------------------------------------------------------
# Supabase — get these from your Supabase project dashboard
# ------------------------------------------------------------------
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_publishable
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_secret

# ------------------------------------------------------------------
# Database — two connection strings are required by Prisma
# ------------------------------------------------------------------
# Transaction pooler (port 6543) — use for production runtime
DATABASE_URL=postgresql://postgres.your_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used by Prisma for migrations
DIRECT_URL=postgresql://postgres.your_ref:your_password@db.your_ref.supabase.co:5432/postgres

# ------------------------------------------------------------------
# AI Agent — OpenRouter
# ------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
# Optional: override the default model
# OPENROUTER_MODEL=deepseek/deepseek-chat
