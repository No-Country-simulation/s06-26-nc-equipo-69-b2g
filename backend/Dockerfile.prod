# ============================================================
# Dockerfile — Production-grade multi-stage build
# Platform: Node 22 + pnpm + Prisma (monorepo)
# Context:  Repo root (not backend/)
# Target:   Render
# ============================================================

# ----------------------------
# Stage 1: Base
# ----------------------------
FROM node:22-alpine AS base

WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

# ----------------------------
# Stage 2: Build (install + Prisma generate)
# ----------------------------
FROM base AS build

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY backend/package.json backend/package.json
COPY backend/scripts backend/scripts
RUN pnpm install --no-frozen-lockfile --filter backend

COPY backend/prisma ./backend/prisma
RUN pnpm --filter backend db:generate

COPY backend/src ./src

# ----------------------------
# Stage 4: Runner — minimal production image
# ----------------------------
FROM node:22-alpine AS runner
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

ENV NODE_ENV=production \
    PORT=3000

# Security: non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 --ingroup nodejs appuser

# Healthcheck dependency
RUN apk add --no-cache wget

# Copy production artifacts from previous stages
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/src ./src
COPY --from=build /app/backend/prisma ./prisma
COPY --from=build /app/backend/package.json ./package.json
COPY docs/Prompt_IA.md /docs/Prompt_IA.md

# Secure ownership
RUN chown -R appuser:nodejs /app
USER appuser

EXPOSE 3000

# Healthcheck against the /health endpoint
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

# Start the server
CMD ["node", "src/server.js"]
