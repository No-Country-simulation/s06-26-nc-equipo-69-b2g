# ============================================================
# App BiT Backend — Development Environment Variables
# ============================================================
# Copy this file to .env and fill in real values for local dev.
#
# DO NOT commit .env or any file with real credentials.
# ============================================================

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------
# Supabase — get these from your Supabase project dashboard
# ------------------------------------------------------------------
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Service role key is optional for local dev (only needed for admin ops)
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------
# Database — optional for local dev (can use Supabase remote)
# ------------------------------------------------------------------
# Connection string from Supabase dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:your_password@db.your_ref.supabase.co:5432/postgres

# Optional direct database connection for local tooling/migrations only.
# Do not commit real passwords. The runtime API does not require this.
DIRECT_URL=

# ------------------------------------------------------------------
# AI Agent / RAG — optional for local dev (defaults to mock/no-RAG responses)
# ------------------------------------------------------------------
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
