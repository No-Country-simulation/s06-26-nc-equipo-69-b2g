# ---------------------------------------------------------------------------
# App BiT -- ETL Configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values.
# All values have sensible defaults — only DATABASE_URL is required for
# PostgreSQL/Supabase deployments.

# --- Database ---
# Type: sqlite | postgresql
# Default: sqlite — ideal for local development/testing
# Switch to postgresql when deploying to Supabase
DB_TYPE=sqlite

# Local SQLite path (used when DB_TYPE=sqlite)
SQLITE_PATH=data/visent.db

# PostgreSQL connection string (used when DB_TYPE=postgresql)
# Format for direct connection:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
# Format for Supabase (transaction pooler, port 6543):
#   DATABASE_URL=postgresql://project.user:password@aws-0-region.pooler.supabase.com:6543/postgres
# DATABASE_URL=

# SSL mode for PostgreSQL (default: require — needed by Supabase)
# Set to "disable" for local PostgreSQL without SSL
SSL_MODE=require

# --- Input data ---
# All paths are relative to the etl-pipeline/ root
DATA_DIR=data
ANTENAS_CSV=data/antenas_flp.csv
CONCENTRACAO_CSV=data/tensor_concentracao.csv
